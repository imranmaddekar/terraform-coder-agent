# ---- Model provider (Microsoft Agent Framework, API-key auth) ----
# azure_openai   = Azure OpenAI / Foundry-hosted GPT deployment (default)
# foundry_claude = Anthropic Claude model deployed in Azure AI Foundry
TFAGENT_MODEL_PROVIDER=azure_openai

# Azure OpenAI / Foundry GPT deployment (TFAGENT_MODEL_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# Claude in Foundry (TFAGENT_MODEL_PROVIDER=foundry_claude). The resource is
# the subdomain before .services.ai.azure.com; Claude uses the /anthropic
# Messages endpoint, not the OpenAI-compatible one. Note: some Claude models
# (e.g. Mythos) are Entra-ID-only and won't work with API-key auth.
#ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource
#ANTHROPIC_FOUNDRY_API_KEY=your-foundry-claude-key
#ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5

# ---- Azure provider (REAL subscription; terraform state stays LOCAL) ----
# Used by the AzureRM provider inside the workspace. A service principal
# scoped to a SANDBOX subscription with least privilege is strongly advised.
ARM_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
ARM_TENANT_ID=00000000-0000-0000-0000-000000000000
ARM_CLIENT_ID=00000000-0000-0000-0000-000000000000
ARM_CLIENT_SECRET=your-sp-secret

# ---- Agent runtime knobs ----
TFAGENT_WORKSPACE=./workspace
TFAGENT_MAX_ITERATIONS=20
TFAGENT_TF_TIMEOUT_SECONDS=600

# ---- Pipeline hand-off (export_to_repo) ----
# Local clone of the repo your deployment pipeline runs from. When set, the
# human-approved export_to_repo tool commits the workspace's *.tf files to a
# new branch there and pushes. When unset, files are copied to ./export/
# instead. State files, saved plans, and .env are never exported.
#TFAGENT_EXPORT_REPO=/path/to/your/infra-repo
#TFAGENT_EXPORT_SUBDIR=terraform
